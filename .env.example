# Backend API base URL (required for login and admin APIs)
# Local development:
NEXT_PUBLIC_API_URL=http://localhost:3000

# Log all API requests/responses in the browser console (optional in production):
# NEXT_PUBLIC_API_DEBUG=true

# Production (Render) — login may 404 if this deployment has no /api/auth/login route:
# NEXT_PUBLIC_API_URL=https://tionix-hrm-backend.onrender.com
