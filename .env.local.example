# Frontend Environment Variables for HRM Admin Panel
# Copy to .env.local for local dev, or set in your hosting provider dashboard

# Backend API base URL (NO trailing slash)
# For local dev with backend on port 5003:
NEXT_PUBLIC_API_URL=http://localhost:5003

# For Render production:
# NEXT_PUBLIC_API_URL=https://quickboom-hrm-backend-gjch.onrender.com

# Log all API requests/responses in the browser console (optional)
# NEXT_PUBLIC_API_DEBUG=true
